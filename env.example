# Environment variables for RAG chatbot
# Copy this file to .env and customize values

# Ollama Settings
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=mistral

# Qdrant Settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# PostgreSQL Settings (optional for metadata store)
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_chatbot_db
POSTGRES_USER=rag_chatbot_user
POSTGRES_PASSWORD=

# Data Directories
DATA_DIR=data

# RAG Pipeline Parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=128
VIDEO_RELEVANCE_THRESHOLD=0.7
PDF_RELEVANCE_THRESHOLD=0.6
TOP_K_VIDEO=3
TOP_K_PDF=3
MAX_CONTEXT_LENGTH=2048

# FastAPI Settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
DEBUG=False
